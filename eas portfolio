<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EAE Portfolio - Accountancy</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: #0b1220;
            color: #eaeaea;
            line-height: 1.6;
            overflow-x: hidden;
        }

        html {
            scroll-behavior: smooth;
        }

        /* Navigation */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            background: rgba(0, 0, 0, 0.8);
            padding: 15px 0;
            display: flex;
            justify-content: center;
            gap: 30px;
            backdrop-filter: blur(10px);
            z-index: 1000;
            box-shadow: 0 2px 20px rgba(212, 175, 55, 0.1);
        }

        nav a {
            color: white;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.3s ease;
            position: relative;
        }

        nav a::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 2px;
            background: #d4af37;
            transition: width 0.3s ease;
        }

        nav a:hover::after {
            width: 100%;
        }

        nav a:hover {
            color: #d4af37;
        }

        /* Hero Section */
        .hero {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            background: linear-gradient(135deg, #1c2f55 0%, #0b1220 100%);
            padding: 20px;
            margin-top: 60px;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: 
                radial-gradient(circle at 20% 50%, rgba(212, 175, 55, 0.1) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(28, 47, 85, 0.2) 0%, transparent 50%);
            pointer-events: none;
        }

        .hero-content {
            position: relative;
            z-index: 1;
            animation: fadeInUp 0.8s ease;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .hero img {
            width: 160px;
            height: 160px;
            border-radius: 50%;
            border: 4px solid #d4af37;
            object-fit: cover;
            margin-bottom: 20px;
            box-shadow: 0 0 40px rgba(212, 175, 55, 0.3);
            animation: float 3s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-20px); }
        }

        .hero h1 {
            font-size: 3.5rem;
            margin: 20px 0;
            color: white;
            font-weight: 700;
        }

        .hero p {
            font-size: 1.5rem;
            color: #d4af37;
            margin-bottom: 20px;
            font-weight: 300;
        }

        .badge {
            display: inline-block;
            margin-top: 15px;
            padding: 10px 20px;
            border: 2px solid #d4af37;
            color: #d4af37;
            border-radius: 25px;
            font-size: 14px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .badge:hover {
            background: #d4af37;
            color: #0b1220;
            transform: scale(1.05);
        }

        .cta-button {
            display: inline-block;
            margin-top: 20px;
            padding: 12px 30px;
            background: #d4af37;
            color: #0b1220;
            text-decoration: none;
            border-radius: 25px;
            font-weight: 600;
            transition: all 0.3s ease;
            cursor: pointer;
            border: none;
            font-size: 14px;
        }

        .cta-button:hover {
            background: white;
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(212, 175, 55, 0.3);
        }

        /* Sections */
        section {
            padding: 100px 12%;
            min-height: 60vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        section:nth-child(even) {
            background: rgba(212, 175, 55, 0.03);
        }

        h2 {
            color: #d4af37;
            margin-bottom: 50px;
            font-size: 2.5rem;
            font-weight: 700;
            position: relative;
            display: inline-block;
        }

        h2::after {
            content: '';
            position: absolute;
            bottom: -15px;
            left: 0;
            width: 60px;
            height: 3px;
            background: #d4af37;
        }

        .card {
            background: #121a2e;
            padding: 30px;
            border-radius: 12px;
            margin: 20px 0;
            border-left: 4px solid #d4af37;
            transition: all 0.3s ease;
            animation: slideIn 0.6s ease;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateX(-20px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .card:hover {
            transform: translateX(10px);
            box-shadow: 0 10px 30px rgba(212, 175, 55, 0.2);
        }

        .card p {
            line-height: 1.8;
            color: #c0c0c0;
        }

        .card ul {
            margin-left: 20px;
            color: #c0c0c0;
        }

        .card li {
            margin-bottom: 10px;
        }

        /* Grid */
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 25px;
            margin-top: 40px;
        }

        .stat {
            text-align: center;
            padding: 30px;
            background: #121a2e;
            border-radius: 12px;
            border-top: 3px solid #d4af37;
            transition: all 0.3s ease;
            animation: fadeInUp 0.6s ease;
        }

        .stat:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 40px rgba(212, 175, 55, 0.2);
        }

        .stat h3 {
            color: #d4af37;
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

        .stat p {
            color: #a0a0a0;
            font-weight: 500;
        }

        /* Contact Section */
        #contact {
            background: linear-gradient(135deg, #1c2f55 0%, #0b1220 100%);
        }

        .contact-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 50px;
            align-items: center;
        }

        .social-links {
            display: flex;
            gap: 20px;
            margin-top: 30px;
        }

        .social-links a {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 50px;
            height: 50px;
            background: #d4af37;
            color: #0b1220;
            border-radius: 50%;
            text-decoration: none;
            transition: all 0.3s ease;
            font-size: 20px;
        }

        .social-links a:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(212, 175, 55, 0.3);
            background: white;
        }

        /* Footer */
        footer {
            text-align: center;
            padding: 40px;
            color: #888;
            background: #000;
            border-top: 1px solid rgba(212, 175, 55, 0.2);
        }

        footer p {
            margin-bottom: 10px;
        }

        /* Responsive */
        @media (max-width: 768px) {
            nav {
                gap: 15px;
                flex-wrap: wrap;
                padding: 10px 0;
            }

            nav a {
                font-size: 12px;
            }

            .hero {
                margin-top: 80px;
            }

            .hero h1 {
                font-size: 2rem;
            }

            .hero p {
                font-size: 1.1rem;
            }

            section {
                padding: 60px 20px;
            }

            h2 {
                font-size: 1.8rem;
            }

            .contact-content {
                grid-template-columns: 1fr;
            }

            .grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 480px) {
            .grid {
                grid-template-columns: 1fr;
            }

            .hero h1 {
                font-size: 1.5rem;
            }

            nav a {
                font-size: 10px;
                gap: 10px;
            }
        }
    </style>
</head>

